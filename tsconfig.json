{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    "paths": {
      "@/*": ["./src/*"],
      "@pages/*": ["./src/pages/*"]
    },

    "strict": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,

    // .js / .jsx are checked for real errors (undefined vars, bad calls, typos)
    // but not nagged for missing types — noImplicitAny off keeps JS type-free.
    // TS/TSX still get the rest of strict (strictNullChecks, etc.).
    "allowJs": true,
    "checkJs": true,
    "noImplicitAny": false,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
